PORT=3000

# Opción A: usar una sola cadena de conexión (Render, Railway, Supabase, etc.)
DATABASE_URL=postgresql://usuario:password@localhost:5432/el_propio_travel
DB_SSL=false

# Opción B: variables sueltas para desarrollo local (usadas si DATABASE_URL no está definida)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=el_propio_travel

# Sesiones (se guardan en la tabla "session" de PostgreSQL vía connect-pg-simple)
SESSION_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# CORS - URL donde corre el frontend
FRONTEND_URL=http://localhost:5173

NODE_ENV=development
